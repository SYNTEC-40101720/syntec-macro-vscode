%@MACRO









ALARM(7);

#1 := GETARG(E);
IF #1 = 4 THEN
	#1 := 1;
END_IF;
#2 := GETARG(Q);
#3 := GETARG(R);
#4 := GETARG(A);
#5 := GETARG(T);
#6 := GETARG(P);


IF #4 = 0 THEN
	
	IF #1 = 1 THEN
		#1 := 2;
	ELSEIF #1 = 2 THEN
		#1 := 1;
	END_IF;
	G10 L1805 I#1 Q#2 R#3 J#5;

ELSEIF #4 = 1 THEN
	SYNCOUT S#1 Q#2 P#6 R#3 L#5;
ELSE
	ALARM(1,"G11.101 Error");
END_IF;

M99;
