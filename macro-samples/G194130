%@MACRO



FOR #300:=0 TO 9 BY 1.0 DO
	#[80+#300] = @[72604+#300];
END_FOR;

IF #80 = 1.000 OR #80 = 2.000 THEN		
	IF #81 > -1 THEN		
		SETDO(#81,1);		
	END_IF;
	
	IF #83 > -1 AND #83 <> #81 THEN		
		SETDO(#83,0);		
	END_IF;
	
	IF #82 > -1 THEN		
		WHILE (READDI(#82)=0) DO		
			SLEEP();
		END_WHILE;
	END_IF;

	IF #84 > -1 AND #84 <> #82 THEN		
		WHILE (READDI(#84)=1) DO		
			SLEEP();
		END_WHILE;
	END_IF;
END_IF;

M99;
