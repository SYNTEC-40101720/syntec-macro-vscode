{
  "name": "syntec-macro",
  "displayName": "SYNTEC 宏程序",
  "description": "为新代（Syntec）CNC 宏程序提供语法高亮、智能补全、悬停文档、G/M代码跳转、实时语法检查",
  "version": "1.4.0",
  "publisher": "syntec-team",
  "repository": {
    "type": "git",
    "url": "https://github.com/SYNTEC-40101720/syntec-macro-vscode"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:syntec-macro"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "syntec-macro",
        "aliases": [
          "Syntec 新代宏程序",
          "Syntec Macro",
          "syntec-macro"
        ],
        "extensions": [
          ".macro",
          ".scp",
          ".G",
          ".nc"
        ],
        "firstLine": "^%@MACRO"
      }
    ],
    "grammars": [
      {
        "language": "syntec-macro",
        "scopeName": "source.syntec-macro",
        "path": "./syntaxes/syntec-macro.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "syntec-macro",
        "path": "./snippets/syntec-macro.json"
      }
    ],
    "configurationDefaults": {
      "[syntec-macro]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": false,
        "editor.autoIndent": "advanced",
        "editor.comment": "//",
        "editor.blockCommentStart": "(*",
        "editor.blockCommentEnd": "*)",
        "editor.colorDecorators": false
      }
    },
    "configuration": {
      "syntecMacro": {
        "type": "object",
        "title": "Syntec 宏程序设置",
        "properties": {
          "enableDiagnostics": {
            "type": "boolean",
            "default": true,
            "description": "启用语法诊断（IF/END_IF 配对、括号匹配）"
          },
          "enableCompletions": {
            "type": "boolean",
            "default": true,
            "description": "启用函数和关键字补全"
          },
          "enableHover": {
            "type": "boolean",
            "default": true,
            "description": "启用悬停文档"
          }
        }
      }
    }
  },
  "scripts": {
    "build": "python build/build_grammar.py && python build/build_snippets.py",
    "package": "npx vsce package --allow-star-activation"
  }
}
